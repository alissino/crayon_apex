create or replace package k_usuario
is
  subtype typ_usuario is varchar2(45);
  
  procedure p_login(prm_cd_usuario in typ_usuario);
  
  function f_ativo
    return typ_usuario;
  

end k_usuario;
/
create or replace package body k_usuario
is
  aux_cd_usuario typ_usuario;
  aux_dt_login   date;
  
  procedure p_login(prm_cd_usuario in typ_usuario)
    is
    begin
      aux_cd_usuario := prm_cd_usuario;
      aux_dt_login   := sysdate;
      
      dbms_session.set_context(namespace => 'x_crayon_usuario',
                               attribute => 'cd_usuario',
                               value     => prm_cd_usuario);
      
    end;
  
  function f_ativo
    return typ_usuario
    is
    begin
      --return nvl(aux_cd_usuario, user);
      return sys_context('x_crayon_usuario', 'cd_usuario');
    end;
  
end k_usuario;
/
