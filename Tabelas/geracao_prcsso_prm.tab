create table GERACAO_PRCSSO_PRM
(
  nr_seq_geracao NUMBER not null,
  cd_prcsso      VARCHAR2(45) not null,
  nr_seq_param   NUMBER not null,
  ds_valor       VARCHAR2(256)
)
;
alter table GERACAO_PRCSSO_PRM
  add constraint PK_GRCPRCPRM primary key (NR_SEQ_GERACAO, CD_PRCSSO, NR_SEQ_PARAM);
alter table GERACAO_PRCSSO_PRM
  add constraint FK_GRCPRCPRM_GRCPRCSSO foreign key (NR_SEQ_GERACAO)
  references GERACAO_PRCSSO (NR_SEQUENCIA);
alter table GERACAO_PRCSSO_PRM
  add constraint FK_GRCPRCPRM_PRCSSOPRM foreign key (CD_PRCSSO, NR_SEQ_PARAM)
  references PROCESSO_PARAM (CD_PRCSSO, NR_SEQUENCIA);

