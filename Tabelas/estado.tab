create table ESTADO
(
  cd_estado NUMBER not null,
  cd_pais   NUMBER not null,
  ds_estado VARCHAR2(45) not null,
  ds_sigla  VARCHAR2(2) not null
)
;
alter table ESTADO
  add constraint PK_ESTADO primary key (CD_ESTADO);
alter table ESTADO
  add constraint FK_ESTADO_PAIS foreign key (CD_PAIS)
  references PAIS (CD_PAIS);

