create table CIDADE
(
  cd_cidade   NUMBER not null,
  cd_estado   NUMBER not null,
  ds_cidade   VARCHAR2(45) not null,
  dm_situacao CHAR(1) default 'A' not null
)
;
alter table CIDADE
  add constraint PK_CIDADE primary key (CD_CIDADE);
alter table CIDADE
  add constraint FK_CIDADE_ESTADO foreign key (CD_ESTADO)
  references ESTADO (CD_ESTADO);

