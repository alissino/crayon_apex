create table CIDADE_CEP
(
  cd_cep        NUMBER not null,
  cd_cidade     NUMBER not null,
  ds_bairro     VARCHAR2(45),
  ds_logradouro VARCHAR2(45)
)
;
alter table CIDADE_CEP
  add constraint PK_CIDCEP primary key (CD_CEP);
alter table CIDADE_CEP
  add constraint FK_CIDCEP_CIDADE foreign key (CD_CIDADE)
  references CIDADE (CD_CIDADE);

