create table RELATORIO_PAGINA_PARAM
(
  nr_sequencia      NUMBER generated always as identity (nocache),
  nr_seq_relat_pag  NUMBER not null,
  cd_processo       VARCHAR2(45) not null,
  nr_seq_prcsso_prm NUMBER not null,
  ds_val_padrao     VARCHAR2(256),
  cd_item_apex      VARCHAR2(45)
)
;
alter table RELATORIO_PAGINA_PARAM
  add constraint PK_RELATPAGPRM primary key (NR_SEQUENCIA);
alter table RELATORIO_PAGINA_PARAM
  add constraint FK_RELATPAGPRM_PRCSSOPRM foreign key (CD_PROCESSO, NR_SEQ_PRCSSO_PRM)
  references PROCESSO_PARAM (CD_PRCSSO, NR_SEQUENCIA) on delete cascade;
alter table RELATORIO_PAGINA_PARAM
  add constraint FK_RELATPAGPRM_RELATPAG foreign key (NR_SEQ_RELAT_PAG)
  references RELATORIO_PAGINA (NR_SEQUENCIA) on delete cascade;

