create table PESSOA_ENDERECO
(
  nr_sequencia   NUMBER generated always as identity (nocache),
  cd_pessoa      NUMBER not null,
  cd_pais        NUMBER not null,
  cd_estado      NUMBER(2) not null,
  cd_cidade      NUMBER(7) not null,
  nr_cep         NUMBER not null,
  ds_logradouro  VARCHAR2(100),
  ds_bairro      VARCHAR2(100),
  ds_numero      VARCHAR2(20),
  ds_complemento VARCHAR2(256),
  dm_situacao    CHAR(1) not null
)
;
alter table PESSOA_ENDERECO
  add constraint PK_PESSEND primary key (NR_SEQUENCIA);
alter table PESSOA_ENDERECO
  add constraint FK_PESSEND_PESSOA foreign key (CD_PESSOA)
  references PESSOA (CD_PESSOA) on delete cascade;

