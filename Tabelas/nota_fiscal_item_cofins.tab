create table NOTA_FISCAL_ITEM_COFINS
(
  cd_nf_item      NUMBER not null,
  dm_cst_cofins   VARCHAR2(3),
  vl_base_calc    NUMBER(15,4),
  vl_aliquota     NUMBER(10,4),
  vl_cofins       NUMBER(15,4),
  cd_regra_fiscal NUMBER
)
;
alter table NOTA_FISCAL_ITEM_COFINS
  add constraint PK_NFITMCOFINS primary key (CD_NF_ITEM);
alter table NOTA_FISCAL_ITEM_COFINS
  add constraint FK_NFITMCOFINS_REG_FISC foreign key (CD_REGRA_FISCAL)
  references REGRA_FISCAL (NR_SEQUENCIA) on delete set null;

