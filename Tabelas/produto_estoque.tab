create table PRODUTO_ESTOQUE
(
  nr_sequencia  NUMBER generated always as identity (nocache),
  cd_produto    NUMBER not null,
  cd_local      NUMBER not null,
  nr_quantidade NUMBER(15,4)
)
;
alter table PRODUTO_ESTOQUE
  add constraint PK_PRODEST primary key (NR_SEQUENCIA);
alter table PRODUTO_ESTOQUE
  add constraint FK_PRODEST_LOCAL foreign key (CD_LOCAL)
  references LOCAL_ESTOQUE (CD_LOCAL);
alter table PRODUTO_ESTOQUE
  add constraint FK_PRODEST_PROD foreign key (CD_PRODUTO)
  references PRODUTO (CD_PRODUTO) on delete cascade;

