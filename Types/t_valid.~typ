create or replace type t_valid as object(
  cd_tabela   varchar2(100),
  dm_operacao varchar2(1),
  vt_colunas  t_valid_col_vet,
  
  constructor function t_valid return self as result,
  constructor function t_valid(prm_cd_tabela varchar2, prm_dm_ins boolean, prm_dm_upd boolean, prm_dm_del boolean) return self as result,
  
  member function f_operacao(prm_dm_ins boolean, prm_dm_upd boolean, prm_dm_del boolean) return varchar2,
  
  member procedure p_add_coluna(prm_cd_coluna varchar2, prm_ds_old varchar2, prm_ds_new varchar2),
  member procedure p_add_coluna(prm_cd_coluna varchar2, prm_ds_old number, prm_ds_new number),
  member procedure p_add_coluna(prm_cd_coluna varchar2, prm_ds_old date, prm_ds_new date),
  
  member procedure p_validar
  
)
/
create or replace type body t_valid is
  
  constructor function t_valid 
    return self as result
    is
    begin
      self.cd_tabela   := null;
      self.dm_operacao := null;
      self.vt_colunas  := t_valid_col_vet();
      return;
    end t_valid;
    
  constructor function t_valid(prm_cd_tabela varchar2, prm_dm_ins boolean, prm_dm_upd boolean, prm_dm_del boolean) 
    return self as result
    is
    begin
      self             := t_valid();
      self.cd_tabela   := upper(trim(prm_cd_tabela));
      self.dm_operacao := self.f_operacao(prm_dm_ins, prm_dm_upd, prm_dm_del);
      return;
    end t_valid;
  
  member function f_operacao(prm_dm_ins boolean, prm_dm_upd boolean, prm_dm_del boolean)
    return varchar2
    is
    begin
      return case
               when prm_dm_ins then k_utils.cns_ins
               when prm_dm_upd then k_utils.cns_upd
               when prm_dm_del then k_utils.cns_del
               else null
             end;
    end f_operacao;
  
  member procedure p_add_coluna(prm_cd_coluna varchar2, 
                                prm_ds_old    varchar2, 
                                prm_ds_new    varchar2)
    is
      aux_coluna t_valid_col := t_valid_col(self.cd_tabela, prm_cd_coluna, prm_ds_new, prm_ds_old);
      aux_nr_col pls_integer := self.vt_colunas.count + 1;
    begin
      self.vt_colunas.extend;
      self.vt_colunas(aux_nr_col) := aux_coluna;
    end p_add_coluna;
    
  member procedure p_add_coluna(prm_cd_coluna varchar2, 
                                prm_ds_old    number, 
                                prm_ds_new    number)
    is
      aux_coluna t_valid_col := t_valid_col(self.cd_tabela, prm_cd_coluna, prm_ds_new, prm_ds_old);
      aux_nr_col pls_integer := self.vt_colunas.count + 1;
    begin
      self.vt_colunas.extend;
      self.vt_colunas(aux_nr_col) := aux_coluna;
    end p_add_coluna;
    
  member procedure p_add_coluna(prm_cd_coluna varchar2, 
                                prm_ds_old    date, 
                                prm_ds_new    date)
    is
      aux_coluna t_valid_col := t_valid_col(self.cd_tabela, prm_cd_coluna, prm_ds_new, prm_ds_old);
      aux_nr_col pls_integer := self.vt_colunas.count + 1;
    begin
      self.vt_colunas.extend;
      self.vt_colunas(aux_nr_col) := aux_coluna;
    end p_add_coluna;
  
  member procedure p_validar
    is
      aux_coluna t_valid_col;
    begin
      for aux_nr_col in 1 .. self.vt_colunas.count loop
        aux_coluna := self.vt_colunas(aux_nr_col);
        if self.dm_operacao <> k_utils.cns_del then
          if aux_coluna.f_buscar_dominio() is not null then
            k_dominio.p_validar_valor(prm_cd_dominio => aux_coluna.f_buscar_dominio(), 
                                      prm_ds_valor   => aux_coluna.ds_valor_new);
          end if;
        end if;
      end loop;
    exception
      when k_utils.e_regra_negocio then
        k_utils.p_erro_regra('Erro de validaçăo!'||chr(13)||
                             'Tab: '||self.cd_tabela||chr(13)||
                             'Col: '||aux_coluna.cd_coluna||chr(13)||
                             'Erro: '||k_utils.f_trata_erro(sqlerrm));
      when others then
        raise;
    end p_validar;
  
end;
/
